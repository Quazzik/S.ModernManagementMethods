<Window x:Class="S.ModernManagementMethods.Views.FurnaceDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:S.ModernManagementMethods.Views"
        mc:Ignorable="d"
        xml:lang="en-US" 
        Title="{Binding Title}" Height="650" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Основные параметры" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Расход природного газа (м³/ч):"/>
                    <TextBox Text="{Binding GasUsage, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged" 
                             Margin="0,2,0,5"/>
                    <TextBlock Text="Минимальный расход (м³/ч):"/>
                    <TextBox Text="{Binding MinimalGasUsage, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                    <TextBlock Text="Максимальный расход (м³/ч):"/>
                    <TextBox Text="{Binding MaximalGasUsage, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Расход кокса (т/ч):"/>
                    <TextBox Text="{Binding CokeCoalUsage, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                    <TextBlock Text="Коэффициент замены кокса:"/>
                    <TextBox Text="{Binding CokeReplacementKoefficient, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Производительность по чугуну (т/ч):"/>
                    <TextBox Text="{Binding CastironProductivity, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Температура горения (°C):"/>
                    <TextBox Text="{Binding BurningTemperature, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                    <TextBlock Text="Минимальная температура (°C):"/>
                    <TextBox Text="{Binding MinimalBurningTemperature, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                    <TextBlock Text="Максимальная температура (°C):"/>
                    <TextBox Text="{Binding MaximalBurningTemperature, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                </StackPanel>

                <TextBlock Text="Коэффициенты влияния" FontWeight="Bold" FontSize="14" Margin="0,10,0,10"/>
                
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Изменение производства при изменении ПГ:"/>
                    <TextBox Text="{Binding ProductivityChangeByGasChange, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                    <TextBlock Text="Изменение производства при изменении кокса:"/>
                    <TextBox Text="{Binding ProductivityChangeByCokeChange, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                    <TextBlock Text="Изменение температуры при изменении газа:"/>
                    <TextBox Text="{Binding TemperatureChangeByGasChange, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="Numeric_PreviewTextInput" TextChanged="Numeric_TextChanged"
                             Margin="0,2,0,5"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Command="{Binding CancelCommand}" 
                    Width="100" Height="30" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Width="100" Height="30" Background="#4CAF50" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>