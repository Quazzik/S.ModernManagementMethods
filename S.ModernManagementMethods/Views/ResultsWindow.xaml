<Window x:Class="S.ModernManagementMethods.Views.ResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:S.ModernManagementMethods.Views"
        mc:Ignorable="d"
        Title="Результаты оптимизации" 
        Height="750" Width="1400"
        WindowState="Maximized">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Результаты оптимизации расхода топлива" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="1" Header="Итоговые показатели" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Общая экономия (руб/ч):" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalMoneySave}" FontSize="18" Foreground="Green" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Общий расход газа (м³/ч):" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalGasUsed}" FontSize="16" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Общий расход кокса (т/ч):" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalCokeUsed}" FontSize="16" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="5">
                    <TextBlock Text="Общее производство (т/ч):" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TotalProduction}" FontSize="16" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Детализация по печам">
            <DataGrid ItemsSource="{Binding SolvedFurnaces}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Газ (м³/ч)" Binding="{Binding SolvedGasUsage}" Width="120"/>
                    <DataGridTextColumn Header="Кокс (т/ч)" Binding="{Binding SolvedCokeCoalUsage}" Width="110"/>
                    <DataGridTextColumn Header="Производство (т/ч)" Binding="{Binding SolvedCastironProductivity}" Width="130"/>
                    <DataGridTextColumn Header="Температура (°C)" Binding="{Binding SolvedBurnTemperature}" Width="120"/>
                    <DataGridTextColumn Header="Экономия (руб/ч)" Binding="{Binding SolvedMoneySave}" Width="130"/>
                    <DataGridCheckBoxColumn Header="Газ в норме" Binding="{Binding IsGasUsageValid, Mode=OneWay}" Width="90"/>
                    <DataGridCheckBoxColumn Header="Температура в норме" Binding="{Binding IsTemperatureValid, Mode=OneWay}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Закрыть" Command="{Binding CloseCommand}" 
                    Width="120" Height="35" Margin="5"/>
            <Button Content="Экспорт в CSV" Command="{Binding ExportCommand}" 
                    Width="120" Height="35" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
